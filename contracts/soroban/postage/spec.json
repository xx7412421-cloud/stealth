    },
    {
      "name": "quote",
      "inputs": [{ "name": "sender_trusted", "type": "bool" }],
      "output": "result:i128:Error"
    },
    {
      "name": "submit",
      "inputs": [
        { "name": "message_id", "type": "bytes32" },
        { "name": "sender", "type": "address" },
        { "name": "recipient", "type": "address" },
        { "name": "amount", "type": "i128" }
      ],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "settle",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "refund",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "dispute",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "expire",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "reclaim",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    },
    {
      "name": "get",
      "inputs": [{ "name": "message_id", "type": "bytes32" }],
      "output": "result:udt:Postage:Error"
    }
